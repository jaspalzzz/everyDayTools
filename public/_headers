# Cloudflare Pages headers. Applied at the edge to the static assets in `out/`.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Security headers on every response.
# NB: Cloudflare MERGES matching _headers rules (it does not pick the most
# specific), so a Cache-Control here would be appended to the /_next/static/*
# rule below and shorten its edge TTL. Cache-Control is therefore set per-path,
# never globally: HTML via functions/_middleware.ts, hashed assets long-immutable
# below, and the regenerated dynamic files (sitemap/robots) short just under.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' https://pagead2.googlesyndication.com https://googletagservices.com https://partner.googleadservices.com https://tpc.googlesyndication.com https://fundingchoicesmessages.google.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net data:; img-src 'self' data: blob: https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net https://fundingchoicesmessages.google.com; connect-src 'self' https://googleads.g.doubleclick.net https://pagead2.googlesyndication.com https://fundingchoicesmessages.google.com https://cloudflareinsights.com; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://fundingchoicesmessages.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# Regenerated on every deploy — a short shared-cache window so updates propagate
# in minutes instead of the platform-default 7 days. (HTML gets the same value
# from the Function; extensionless HTML paths can't be matched here.)
/sitemap.xml
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate
/robots.txt
  Cache-Control: public, max-age=0, s-maxage=600, must-revalidate

# The OG/Twitter images are emitted without a file extension, so Cloudflare
# would serve them as octet-stream. Force image/png so social scrapers accept them.
/opengraph-image
  Content-Type: image/png

/twitter-image
  Content-Type: image/png

# Next.js content-hashes every file under /_next/static/ — the filename itself
# changes whenever the content does, so it's safe to cache these forever at both
# the browser and the edge. This is the only Cache-Control matching these paths
# (the /* block sets none), so no rule-merge shortens the edge TTL.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
